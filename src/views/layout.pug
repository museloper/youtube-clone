doctype html
html(lang='ko')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    link(rel='stylesheet', href='https://unpkg.com/mvp.css')
    title #{ title } | Notube
  body
    header
      nav
        ul
          if user.loggedIn
            small Hello, #{ user.username }
            li
              a(href='/logout') Logout
          else
            li
              a(href='/login') Login
      h1= title
    main
      block content
    include partials/footer.pug
